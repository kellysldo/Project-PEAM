<svg width="900" height="600" xmlns="http://www.w3.org/2000/svg" font-family="Arial, sans-serif" font-size="13">

  <!-- Background -->
  <rect width="900" height="600" fill="#f8f9fa"/>

  <!-- Title -->
  <text x="450" y="35" text-anchor="middle" font-size="18" font-weight="bold" fill="#2c3e50">Relational Model — Events Attendance Manager System</text>

  <!-- ===== USERS TABLE ===== -->
  <rect x="50" y="60" width="200" height="130" rx="6" fill="#ffffff" stroke="#3498db" stroke-width="2"/>
  <rect x="50" y="60" width="200" height="32" rx="6" fill="#3498db"/>
  <rect x="50" y="86" width="200" height="6" fill="#3498db"/>
  <text x="150" y="82" text-anchor="middle" font-weight="bold" fill="white" font-size="14">users</text>
  <text x="65" y="114" fill="#2c3e50" text-decoration="underline" font-weight="bold">user_id (PK)</text>
  <text x="65" y="134" fill="#2c3e50">username</text>
  <text x="65" y="154" fill="#2c3e50">password</text>

  <!-- ===== EVENTS TABLE ===== -->
  <rect x="50" y="290" width="220" height="190" rx="6" fill="#ffffff" stroke="#2ecc71" stroke-width="2"/>
  <rect x="50" y="290" width="220" height="32" rx="6" fill="#2ecc71"/>
  <rect x="50" y="316" width="220" height="6" fill="#2ecc71"/>
  <text x="160" y="312" text-anchor="middle" font-weight="bold" fill="white" font-size="14">events</text>
  <text x="65" y="344" fill="#2c3e50" text-decoration="underline" font-weight="bold">event_id (PK)</text>
  <text x="65" y="364" fill="#e74c3c" font-style="italic">user_id (FK)</text>
  <text x="65" y="384" fill="#2c3e50">event_name</text>
  <text x="65" y="404" fill="#2c3e50">event_date</text>
  <text x="65" y="424" fill="#2c3e50">location</text>
  <text x="65" y="444" fill="#2c3e50">description</text>

  <!-- ===== ATTENDEES TABLE ===== -->
  <rect x="630" y="60" width="220" height="170" rx="6" fill="#ffffff" stroke="#9b59b6" stroke-width="2"/>
  <rect x="630" y="60" width="220" height="32" rx="6" fill="#9b59b6"/>
  <rect x="630" y="86" width="220" height="6" fill="#9b59b6"/>
  <text x="740" y="82" text-anchor="middle" font-weight="bold" fill="white" font-size="14">attendees</text>
  <text x="645" y="114" fill="#2c3e50" text-decoration="underline" font-weight="bold">attendee_id (PK)</text>
  <text x="645" y="134" fill="#2c3e50">fullname</text>
  <text x="645" y="154" fill="#2c3e50">email</text>
  <text x="645" y="174" fill="#2c3e50">contact_no</text>
  <text x="645" y="194" fill="#2c3e50">address</text>

  <!-- ===== REGISTRATIONS TABLE ===== -->
  <rect x="580" y="310" width="250" height="210" rx="6" fill="#ffffff" stroke="#e67e22" stroke-width="2"/>
  <rect x="580" y="310" width="250" height="32" rx="6" fill="#e67e22"/>
  <rect x="580" y="336" width="250" height="6" fill="#e67e22"/>
  <text x="705" y="332" text-anchor="middle" font-weight="bold" fill="white" font-size="14">registrations</text>
  <text x="595" y="364" fill="#2c3e50" text-decoration="underline" font-weight="bold">registration_id (PK)</text>
  <text x="595" y="384" fill="#e74c3c" font-style="italic">attendee_id (FK)</text>
  <text x="595" y="404" fill="#e74c3c" font-style="italic">event_id (FK)</text>
  <text x="595" y="424" fill="#2c3e50">attendance_status</text>
  <text x="595" y="444" fill="#2c3e50">registration_date</text>
  <text x="595" y="464" fill="#2c3e50">qr_code</text>

  <!-- ===== RELATIONSHIP LINES ===== -->

  <!-- users → events (1 to many): vertical line down -->
  <line x1="150" y1="190" x2="150" y2="290" stroke="#3498db" stroke-width="2" marker-end="url(#arrow)"/>
  <text x="155" y="230" fill="#3498db" font-size="11">1</text>
  <text x="155" y="280" fill="#3498db" font-size="11">N</text>

  <!-- events → registrations (1 to many): horizontal line right -->
  <line x1="270" y1="400" x2="580" y2="400" stroke="#2ecc71" stroke-width="2" marker-end="url(#arrow)"/>
  <text x="390" y="392" fill="#2ecc71" font-size="11">1</text>
  <text x="560" y="392" fill="#2ecc71" font-size="11">N</text>

  <!-- attendees → registrations (1 to many): vertical line down -->
  <line x1="740" y1="230" x2="740" y2="310" stroke="#9b59b6" stroke-width="2" marker-end="url(#arrow)"/>
  <text x="745" y="265" fill="#9b59b6" font-size="11">1</text>
  <text x="745" y="302" fill="#9b59b6" font-size="11">N</text>

  <!-- Arrow marker -->
  <defs>
    <marker id="arrow" markerWidth="10" markerHeight="7" refX="9" refY="3.5" orient="auto">
      <polygon points="0 0, 10 3.5, 0 7" fill="#555"/>
    </marker>
  </defs>

  <!-- Legend -->
  <rect x="320" y="520" width="260" height="60" rx="6" fill="#ffffff" stroke="#bdc3c7" stroke-width="1"/>
  <text x="330" y="540" font-size="12" fill="#2c3e50" font-weight="bold">Legend</text>
  <text x="330" y="558" font-size="12" fill="#2c3e50" text-decoration="underline">underlined</text>
  <text x="410" y="558" font-size="12" fill="#2c3e50"> = Primary Key (PK)</text>
  <text x="330" y="574" font-size="12" fill="#e74c3c" font-style="italic">italic red</text>
  <text x="380" y="574" font-size="12" fill="#2c3e50"> = Foreign Key (FK)</text>

</svg>
